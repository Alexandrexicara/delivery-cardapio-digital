    </div>

    <footer>
        <p>Cardápio Digital Universal &copy; 2025 - Sistema de pedidos automatizado</p>
    </footer>

    <script>
        // Load establishment data on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Check if admin has proper access
            const adminAccess = localStorage.getItem('adminAccess');
            const establishmentData = localStorage.getItem('establishmentData');
            
            if (!adminAccess || !establishmentData) {
                // Redirect to login page if no proper authentication
                window.location.href = 'login.html';
                return;
            }
            
            const data = JSON.parse(establishmentData);
            if (data && data.isAuthenticated) {
                document.getElementById('adminName').textContent = 'Administrador - ' + data.establishmentName;
            } else {
                // Redirect to login page if not properly authenticated
                window.location.href = 'login.html';
            }
            
            // Initialize WebSocket connection
            initWebSocket();
        });
        
        // Preview menu function
        function previewMenu() {
            // Always open the regular user interface
            window.open('usuario.html', '_blank');
        }
        
        // Tab navigation
        function showSection(sectionId) {
            // Hide all sections
            document.querySelectorAll('.content-section').forEach(section => {
                section.classList.remove('active');
            });
            
            // Show selected section
            document.getElementById(sectionId).classList.add('active');
            
            // Update tab active state
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.remove('active');
            });
            
            // Find and activate the corresponding tab
            const tabs = document.querySelectorAll('.tab');
            const sectionMap = {
                'dashboard': 0,
                'orders': 1,
                'kitchen': 2,
                'counter': 3,
                'payments': 4,
                'reports': 5,
                'inventory': 6,
                'notifications': 7,
                'history': 8,
                'combined': 9  // New section
            };
            
            if (sectionMap[sectionId] !== undefined && sectionMap[sectionId] < tabs.length) {
                tabs[sectionMap[sectionId]].classList.add('active');
            }
            
            // Load history if needed
            if (sectionId === 'history') {
                loadOrderHistory();
            }
            
            // Load payments if needed
            if (sectionId === 'payments') {
                loadPayments();
            }
            
            // Load combined orders if needed
            if (sectionId === 'combined') {
                loadCombinedOrders();
            }
        }
        
        // Load payments
        function loadPayments() {
            // In a real implementation, this would fetch pending payments from the server
            // For now, we'll just update the UI to show that we're ready to receive payments
            const paymentsList = document.getElementById('paymentsList');
            paymentsList.innerHTML = '<p>Aguardando novos pagamentos...</p>';
        }
        
        // Sector toggle
        function toggleSector(button, sector) {
            // Remove active class from all buttons
            document.querySelectorAll('.sector-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            
            // Add active class to clicked button
            button.classList.add('active');
            
            // Filter the orders by sector
            console.log(`Filtrando por setor: ${sector}`);
            // In a production environment, this would filter the orders by sector
        }
        
        // Update order status
        function updateOrderStatus(orderId, status, sector = 'admin') {
            if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                window.ws.send(JSON.stringify({
                    type: 'updateStatus',
                    orderId: orderId,
                    status: status,
                    updatedBy: sector
                }));
                
                // Log the action
                console.log('Atualizando status do pedido:', orderId, 'para', status);
                
                // Save this action to order history
                const action = {
                    type: 'updateStatus',
                    orderId: orderId,
                    status: status,
                    sector: sector,
                    timestamp: new Date().toISOString()
                };
                
                // Get existing actions
                let orderActions = JSON.parse(localStorage.getItem('orderActions') || '[]');
                
                // Add new action
                orderActions.push(action);
                
                // Save back to localStorage
                localStorage.setItem('orderActions', JSON.stringify(orderActions));
                
                // Update UI immediately
                updateOrderStatusUI(orderId, status);
                
                // Show notification based on status
                let notificationMessage = '';
                switch (status) {
                    case 'preparing':
                        notificationMessage = `Pedido ${orderId} está em preparação`;
                        break;
                    case 'ready':
                        notificationMessage = `Pedido ${orderId} está pronto - Notificar garçom para entrega`;
                        break;
                    case 'delivered':
                        notificationMessage = `Pedido ${orderId} foi entregue ao cliente`;
                        break;
                    case 'completed':
                        notificationMessage = `Pedido ${orderId} foi concluído pelo cliente`;
                        break;
                }
                
                if (notificationMessage) {
                    alert(notificationMessage);
                }
            } else {
                alert('Erro na conexão. Por favor, recarregue a página.');
            }
        }
        
        // Add notification section to the dashboard
        function addNotificationToDashboard(message, orderId) {
            const notificationsColumn = document.querySelector('#notifications .orders-column');
            if (notificationsColumn) {
                const notificationElement = document.createElement('div');
                notificationElement.className = 'order-card';
                notificationElement.style.borderLeft = '4px solid #3498db';
                notificationElement.innerHTML = `
                    <div class="order-header">
                        <div class="order-id">Notificação</div>
                        <div class="order-table">${new Date().toLocaleTimeString()}</div>
                    </div>
                    <div>${message}</div>
                    ${orderId ? `<div>Pedido: <strong>${orderId}</strong></div>` : ''}
                `;
                
                const columnHeader = notificationsColumn.querySelector('.column-header');
                if (columnHeader) {
                    notificationsColumn.insertBefore(notificationElement, columnHeader.nextSibling);
                } else {
                    notificationsColumn.appendChild(notificationElement);
                }
            }
        }
        
        // Add new order to dashboard
        function addNewOrderToDashboard(order) {
            // Create order card element
            const orderCard = document.createElement('div');
            orderCard.className = 'order-card';
            orderCard.innerHTML = `
                <div class="order-header">
                    <div class="order-id">${order.id}</div>
                    <div class="order-table">${order.table || 'N/A'}</div>
                </div>
                <div class="order-customer">${order.customer.fullName || 'Cliente'} - ${order.customer.phone || ''}</div>
                <div class="order-items">
                    ${order.items.map(item => {
                        // Garante que quantity e price sejam números
                        const quantity = typeof item.quantity === 'number' ? item.quantity : parseInt(item.quantity) || 0;
                        const price = typeof item.price === 'number' ? item.price : parseFloat(item.price) || 0;
                        const itemTotal = price * quantity;
                        
                        return `
                        <div class="order-item">
                            <span>${item.name}</span>
                            <span>R$ ${itemTotal.toFixed(2).replace('.', ',')}</span>
                        </div>
                    `}).join('')}
                </div>
                <div class="order-total">
                    <div>Subtotal: R$ ${(order.subtotal || 0).toFixed(2).replace('.', ',')}</div>
                    <div>Taxa de Serviço (10%): R$ ${(order.serviceFee || 0).toFixed(2).replace('.', ',')}</div>
                    <div style="font-weight: bold;">Total: R$ ${order.total.toFixed(2).replace('.', ',')}</div>
                </div>
                <div class="order-status" style="margin: 10px 0; padding: 5px; background-color: #f8f9fa; border-radius: 5px;">
                    Status: <strong style="color: ${getStatusColor(order.status)};">${getStatusText(order.status)}</strong>
                </div>
                <div class="order-status" style="margin: 10px 0; padding: 5px; background-color: #f8f9fa; border-radius: 5px;">
                    Pagamento: <strong style="color: ${getPaymentStatusColor(order.paymentStatus || 'pending')};">${getPaymentStatusText(order.paymentStatus || 'pending')}</strong>
                </div>
                <div class="order-actions">
                    <button class="btn btn-primary" onclick="updateOrderStatus('${order.id}', 'preparing')">Preparando</button>
                    <button class="btn btn-warning" onclick="updateOrderStatus('${order.id}', 'ready')">Pronto</button>
                    <button class="btn btn-success" onclick="updateOrderStatus('${order.id}', 'delivered')">Entregue</button>
                </div>
            `;
            
            // Add to recent orders column
            const recentOrdersColumn = document.querySelector('#dashboard .orders-column:first-child');
            if (recentOrdersColumn) {
                const columnHeader = recentOrdersColumn.querySelector('.column-header');
                if (columnHeader) {
                    recentOrdersColumn.insertBefore(orderCard, columnHeader.nextSibling);
                } else {
                    recentOrdersColumn.appendChild(orderCard);
                }
            }
        }
        
        // Add new order to orders section
        function addNewOrderToOrdersSection(order) {
            // Create order card element
            const orderCard = document.createElement('div');
            orderCard.className = 'order-card';
            orderCard.innerHTML = `
                <div class="order-header">
                    <div class="order-id">${order.id}</div>
                    <div class="order-table">${order.table || 'N/A'}</div>
                </div>
                <div class="order-customer">${order.customer.fullName || 'Cliente'} - ${order.customer.phone || ''}</div>
                <div class="order-items">
                    ${order.items.map(item => {
                        // Garante que quantity e price sejam números
                        const quantity = typeof item.quantity === 'number' ? item.quantity : parseInt(item.quantity) || 0;
                        const price = typeof item.price === 'number' ? item.price : parseFloat(item.price) || 0;
                        const itemTotal = price * quantity;
                        
                        return `
                        <div class="order-item">
                            <span>${item.name}</span>
                            <span>R$ ${itemTotal.toFixed(2).replace('.', ',')}</span>
                        </div>
                    `}).join('')}
                </div>
                <div class="order-total">
                    <div>Subtotal: R$ ${(order.subtotal || 0).toFixed(2).replace('.', ',')}</div>
                    <div>Taxa de Serviço (10%): R$ ${(order.serviceFee || 0).toFixed(2).replace('.', ',')}</div>
                    <div style="font-weight: bold;">Total: R$ ${order.total.toFixed(2).replace('.', ',')}</div>
                </div>
                <div class="order-status" style="margin: 10px 0; padding: 5px; background-color: #f8f9fa; border-radius: 5px;">
                    Status: <strong style="color: ${getStatusColor(order.status)};">${getStatusText(order.status)}</strong>
                </div>
                <div class="order-status" style="margin: 10px 0; padding: 5px; background-color: #f8f9fa; border-radius: 5px;">
                    Pagamento: <strong style="color: ${getPaymentStatusColor(order.paymentStatus || 'pending')};">${getPaymentStatusText(order.paymentStatus || 'pending')}</strong>
                </div>
                <div class="order-actions">
                    <button class="btn btn-primary" onclick="updateOrderStatus('${order.id}', 'preparing')">Preparando</button>
                    <button class="btn btn-warning" onclick="updateOrderStatus('${order.id}', 'ready')">Pronto</button>
                    <button class="btn btn-success" onclick="updateOrderStatus('${order.id}', 'delivered')">Entregue</button>
                </div>
            `;
            
            // Add to orders column
            const ordersColumn = document.querySelector('#orders .orders-column');
            if (ordersColumn) {
                const columnHeader = ordersColumn.querySelector('.column-header');
                if (columnHeader) {
                    ordersColumn.insertBefore(orderCard, columnHeader.nextSibling);
                } else {
                    ordersColumn.appendChild(orderCard);
                }
            }
        }
        
        // Add new order to kitchen section
        function addNewOrderToKitchenSection(order) {
            // Filter items for kitchen (main courses and appetizers)
            const kitchenItems = order.items.filter(item => 
                item.category === 'main' || item.category === 'appetizer');
            
            if (kitchenItems.length === 0) return; // No kitchen items
            
            // Create order card element
            const orderCard = document.createElement('div');
            orderCard.className = 'order-card';
            orderCard.innerHTML = `
                <div class="order-header">
                    <div class="order-id">${order.id}</div>
                    <div class="order-table">${order.table || 'N/A'}</div>
                </div>
                <div class="order-customer">${order.customer.fullName || 'Cliente'}</div>
                <div class="order-items">
                    ${kitchenItems.map(item => {
                        // Garante que quantity seja número
                        const quantity = typeof item.quantity === 'number' ? item.quantity : parseInt(item.quantity) || 0;
                        
                        return `
                        <div class="order-item">
                            <span>${item.name}</span>
                            <span>${quantity}x</span>
                        </div>
                    `}).join('')}
                </div>
                ${order.observations ? `
                <div class="order-observations">
                    <small><strong>Observações:</strong> ${order.observations}</small>
                </div>
                ` : ''}
                <div class="order-actions">
                    <button class="btn btn-warning" onclick="updateOrderStatus('${order.id}', 'ready', 'kitchen')">Pronto</button>
                </div>
            `;
            
            // Add to kitchen orders column
            const kitchenColumn = document.querySelector('#kitchen .orders-column:first-child');
            if (kitchenColumn) {
                const columnHeader = kitchenColumn.querySelector('.column-header');
                if (columnHeader) {
                    kitchenColumn.insertBefore(orderCard, columnHeader.nextSibling);
                } else {
                    kitchenColumn.appendChild(orderCard);
                }
            }
        }
        
        // Add new order to counter section
        function addNewOrderToCounterSection(order) {
            // Filter items for counter (drinks and desserts)
            const counterItems = order.items.filter(item => 
                item.category === 'drink' || item.category === 'dessert');
            
            if (counterItems.length === 0) return; // No counter items
            
            // Create order card element
            const orderCard = document.createElement('div');
            orderCard.className = 'order-card';
            orderCard.innerHTML = `
                <div class="order-header">
                    <div class="order-id">${order.id}</div>
                    <div class="order-table">${order.table || 'N/A'}</div>
                </div>
                <div class="order-customer">${order.customer.fullName || 'Cliente'}</div>
                <div class="order-items">
                    ${counterItems.map(item => {
                        // Garante que quantity seja número
                        const quantity = typeof item.quantity === 'number' ? item.quantity : parseInt(item.quantity) || 0;
                        
                        return `
                        <div class="order-item">
                            <span>${item.name}</span>
                            <span>${quantity}x</span>
                        </div>
                    `}).join('')}
                </div>
                <div class="order-actions">
                    <button class="btn btn-warning" onclick="updateOrderStatus('${order.id}', 'ready', 'counter')">Pronto</button>
                </div>
            `;
            
            // Add to counter orders column
            const counterColumn = document.querySelector('#counter .orders-column:first-child');
            if (counterColumn) {
                const columnHeader = counterColumn.querySelector('.column-header');
                if (columnHeader) {
                    counterColumn.insertBefore(orderCard, columnHeader.nextSibling);
                } else {
                    counterColumn.appendChild(orderCard);
                }
            }
        }
        
        // Add order to payments section
        function addOrderToPaymentsSection(order) {
            // Create payment card element
            const paymentCard = document.createElement('div');
            paymentCard.className = 'order-card';
            paymentCard.innerHTML = `
                <div class="order-header">
                    <div class="order-id">${order.id}</div>
                    <div class="order-table">${order.table || 'N/A'}</div>
                </div>
                <div class="order-customer">${order.customer.fullName || 'Cliente'} - ${order.customer.phone || ''}</div>
                <div class="order-items">
                    ${order.items.map(item => {
                        // Garante que quantity e price sejam números
                        const quantity = typeof item.quantity === 'number' ? item.quantity : parseInt(item.quantity) || 0;
                        const price = typeof item.price === 'number' ? item.price : parseFloat(item.price) || 0;
                        const itemTotal = price * quantity;
                        
                        return `
                        <div class="order-item">
                            <span>${item.name}</span>
                            <span>R$ ${itemTotal.toFixed(2).replace('.', ',')}</span>
                        </div>
                    `}).join('')}
                </div>
                <div class="order-total">
                    <div>Subtotal: R$ ${(order.subtotal || 0).toFixed(2).replace('.', ',')}</div>
                    <div>Taxa de Serviço (10%): R$ ${(order.serviceFee || 0).toFixed(2).replace('.', ',')}</div>
                    <div style="font-weight: bold;">Total: R$ ${order.total.toFixed(2).replace('.', ',')}</div>
                </div>
                <div class="order-status" style="margin: 10px 0; padding: 5px; background-color: #f8f9fa; border-radius: 5px;">
                    Status de Pagamento: <strong style="color: ${getPaymentStatusColor(order.paymentStatus)};">${getPaymentStatusText(order.paymentStatus)}</strong>
                </div>
                <div class="order-actions">
                    <button class="btn btn-success" onclick="confirmPayment('${order.id}')">Confirmar Pagamento</button>
                </div>
            `;
            
            // Add to payments column
            const paymentsColumn = document.querySelector('#payments .orders-column');
            if (paymentsColumn) {
                const columnHeader = paymentsColumn.querySelector('.column-header');
                if (columnHeader) {
                    paymentsColumn.insertBefore(paymentCard, columnHeader.nextSibling);
                } else {
                    paymentsColumn.appendChild(paymentCard);
                }
            }
        }
        
        // Update payment status in UI
        function updatePaymentStatusUI(orderId, paymentStatus) {
            const orderCards = document.querySelectorAll('.order-card');
            orderCards.forEach(card => {
                const orderIdElement = card.querySelector('.order-id');
                if (orderIdElement && orderIdElement.textContent === orderId) {
                    const paymentStatusElement = card.querySelector('.order-status strong');
                    if (paymentStatusElement) {
                        paymentStatusElement.textContent = getPaymentStatusText(paymentStatus);
                        paymentStatusElement.style.color = getPaymentStatusColor(paymentStatus);
                        
                        // If payment is completed, remove the card from payments section
                        if (paymentStatus === 'completed') {
                            // Check if this card is in the payments section
                            const paymentsSection = document.getElementById('payments');
                            if (paymentsSection && paymentsSection.contains(card)) {
                                card.remove();
                            }
                        }
                    }
                }
            });
        }
        
        // Confirm payment
        function confirmPayment(orderId) {
            if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                window.ws.send(JSON.stringify({
                    type: 'updatePaymentStatus',
                    orderId: orderId,
                    paymentStatus: 'completed',
                    updatedBy: 'admin'
                }));
                
                // Show confirmation
                alert(`Pagamento do pedido ${orderId} confirmado com sucesso!`);
            } else {
                alert('Erro na conexão. Por favor, recarregue a página.');
            }
        }
        
        // Clear order history after payment is completed
        function clearOrderHistory(orderId) {
            // Get existing user orders from localStorage
            let userOrders = JSON.parse(localStorage.getItem('userOrders') || '[]');
            
            // Filter out the completed order
            userOrders = userOrders.filter(order => order.id !== orderId);
            
            // Save back to localStorage
            localStorage.setItem('userOrders', JSON.stringify(userOrders));
            
            // Reload the order history display if the history section is active
            if (document.getElementById('history').classList.contains('active')) {
                loadOrderHistory();
            }
            
            console.log(`Histórico de pedidos limpo para o pedido: ${orderId}`);
        }
        
        // Get status color
        function getStatusColor(status) {
            switch (status) {
                case 'pending': return '#f39c12';
                case 'preparing': return '#3498db';
                case 'ready': return '#27ae60';
                case 'delivered': return '#9b59b6';
                default: return '#7f8c8d';
            }
        }
        
        // Get status text
        function getStatusText(status) {
            switch (status) {
                case 'pending': return 'Pendente';
                case 'preparing': return 'Em Preparo';
                case 'ready': return 'Pronto';
                case 'delivered': return 'Entregue';
                default: return status;
            }
        }
        
        // Get payment status color
        function getPaymentStatusColor(paymentStatus) {
            switch (paymentStatus) {
                case 'pending': return '#f39c12';
                case 'completed': return '#27ae60';
                default: return '#7f8c8d';
            }
        }
        
        // Get payment status text
        function getPaymentStatusText(paymentStatus) {
            switch (paymentStatus) {
                case 'pending': return 'Pendente';
                case 'completed': return 'Pago';
                default: return paymentStatus;
            }
        }
        
        // Initialize WebSocket connection
        function initWebSocket() {
            // Check if we're already connected
            if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                console.log('Já conectado ao servidor WebSocket');
                return;
            }
            
            // Connect to port 3002
            const ws = new WebSocket('ws://localhost:3002');
            
            ws.onopen = function() {
                console.log('Conectado ao servidor WebSocket');
                window.ws = ws;
                
                // Request existing orders when connection is established
                if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                    window.ws.send(JSON.stringify({
                        type: 'getExistingOrders'
                    }));
                }
            };
            
            ws.onmessage = function(event) {
                const data = JSON.parse(event.data);
                
                if (data.type === 'existingOrders') {
                    // Store orders data for combined view
                    window.ordersData = data.orders || [];
                    
                    // Load existing orders into the dashboard
                    var orders = data.orders || [];
                    for (var i = 0; i < orders.length; i++) {
                        var order = orders[i];


