        // Initialize WebSocket connection
        initWebSocket();
        
        // Add event listeners for navigation
        document.querySelectorAll('nav a').forEach(function(navLink) {
            navLink.addEventListener('click', function(event) {
                event.preventDefault();
                const targetSection = event.target.getAttribute('href').substring(1);
                document.querySelectorAll('section').forEach(function(section) {
                    section.style.display = 'none';
                });
                document.getElementById(targetSection).style.display = 'block';
                document.querySelectorAll('nav a').forEach(function(link) {
                    link.classList.remove('active');
                });
                event.target.classList.add('active');
                
                // Load or refresh content for the target section
                if (targetSection === 'history') {
                    loadOrderHistory();
                } else if (targetSection === 'combined') {
                    loadCombinedOrders();
                }
            });
        });
        
        // Display combined orders
        function displayCombinedOrders(orders) {
            const combinedOrdersList = document.getElementById('combinedOrdersList');
            const combinedOrdersCount = document.getElementById('combinedOrdersCount');
            
            // Apply filters
            const dateFilter = document.getElementById('combinedDateFilter').value;
            const tableFilter = document.getElementById('combinedTableFilter').value;
            const statusFilter = document.getElementById('combinedStatusFilter').value;
            const paymentFilter = document.getElementById('combinedPaymentFilter').value;
            
            let filteredOrders = [].concat(orders);
            
            // Apply date filter
            if (dateFilter) {
                filteredOrders = filteredOrders.filter(function(order) {
                    const orderDate = new Date(order.timestamp);
                    const filterDate = new Date(dateFilter);
                    return orderDate.toDateString() === filterDate.toDateString();
                });
            }
            
            // Apply table filter
            if (tableFilter) {
                filteredOrders = filteredOrders.filter(function(order) {
                    const tableNumber = order.table ? order.table.replace('Mesa ', '') : '';
                    return tableNumber === tableFilter;
                });
            }
            
            // Apply status filter
            if (statusFilter) {
                filteredOrders = filteredOrders.filter(function(order) {
                    return order.status === statusFilter;
                });
            }
            
            // Apply payment filter
            if (paymentFilter) {
                filteredOrders = filteredOrders.filter(function(order) {
                    const paymentStatus = order.paymentStatus || 'pending';
                    return paymentStatus === paymentFilter;
                });
            }
            
            // Update orders count
            combinedOrdersCount.textContent = filteredOrders.length + ' pedidos encontrados';
            
            if (filteredOrders.length === 0) {
                combinedOrdersList.innerHTML = '<p>Nenhum pedido encontrado com os filtros aplicados.</p>';
                updateCombinedSummary({subtotal: 0, serviceFee: 0, total: 0, paid: 0, pending: 0}, orders);
                return;
            }
            
            // Sort orders by timestamp (newest first)
            filteredOrders.sort(function(a, b) {
                return new Date(b.timestamp) - new Date(a.timestamp);
            });
            
            // Clear the list
            combinedOrdersList.innerHTML = '';
            
            // Calculate totals
            let totalSubtotal = 0;
            let totalServiceFee = 0;
            let totalGeneral = 0;
            let totalPaid = 0;
            let totalPending = 0;
            
            // Add each order to the list
            filteredOrders.forEach(function(order) {
                // Ensure order has all required properties
                const orderId = order.id || 'N/A';
                const orderTable = order.table || 'N/A';
                const customerName = (order.customer && order.customer.fullName) || 'Cliente';
                const customerPhone = (order.customer && order.customer.phone) || '';
                
                const orderCard = document.createElement('div');
                orderCard.className = 'order-card';
                
                // Build items HTML
                let itemsHTML = '';
                var items = order.items || [];
                for (var i = 0; i < items.length; i++) {
                    var item = items[i];
                    // Garante que quantity e price sejam números
                    const quantity = typeof item.quantity === 'number' ? item.quantity : parseInt(item.quantity) || 0;
                    const price = typeof item.price === 'number' ? item.price : parseFloat(item.price) || 0;
                    const itemTotal = price * quantity;
                    
                    itemsHTML += '<div class="order-item">';
                    itemsHTML += '<span>' + item.name + ' (x' + quantity + ')</span>';
                    itemsHTML += '<span>R$ ' + itemTotal.toFixed(2).replace('.', ',') + '</span>';
                    itemsHTML += '</div>';
                }
                
                // Build status color
                const statusColor = getStatusColor(order.status || 'pending');
                const statusText = getStatusText(order.status || 'pending');
                const paymentStatusColor = getPaymentStatusColor(order.paymentStatus || 'pending');
                const paymentStatusText = getPaymentStatusText(order.paymentStatus || 'pending');
                
                orderCard.innerHTML = 
                    '<div class="order-header">' +
                        '<div class="order-id">' + orderId + '</div>' +
                        '<div class="order-table">' + orderTable + '</div>' +
                    '</div>' +
                    '<div class="order-customer">' + customerName + ' - ' + customerPhone + '</div>' +
                    '<div class="order-items">' +
                        itemsHTML +
                    '</div>' +
                    '<div class="order-total">' +
                        '<div>Subtotal: R$ ' + ((order.subtotal || 0)).toFixed(2).replace('.', ',') + '</div>' +
                        '<div>Taxa de Serviço (10%): R$ ' + ((order.serviceFee || 0)).toFixed(2).replace('.', ',') + '</div>' +
                        '<div style="font-weight: bold;">Total: R$ ' + ((order.total || 0)).toFixed(2).replace('.', ',') + '</div>' +
                    '</div>' +
                    '<div class="order-status" style="margin: 10px 0; padding: 5px; background-color: #f8f9fa; border-radius: 5px;">' +
                        'Status: <strong style="color: ' + statusColor + ';">' + statusText + '</strong>' +
                    '</div>' +
                    '<div class="order-status" style="margin: 10px 0; padding: 5px; background-color: #f8f9fa; border-radius: 5px;">' +
                        'Pagamento: <strong style="color: ' + paymentStatusColor + ';">' + paymentStatusText + '</strong>' +
                    '</div>' +
                    '<div class="order-actions">' +
                        '<button class="btn btn-primary" onclick="updateOrderStatus(\'' + orderId + '\', \'preparing\')">Preparando</button>' +
                        '<button class="btn btn-warning" onclick="updateOrderStatus(\'' + orderId + '\', \'ready\')">Pronto</button>' +
                        '<button class="btn btn-success" onclick="updateOrderStatus(\'' + orderId + '\', \'delivered\')">Entregue</button>' +
                        (order.paymentStatus !== 'completed' ? '<button class="btn btn-info" onclick="confirmPayment(\'' + orderId + '\')">Confirmar Pagamento</button>' : '') +
                    '</div>';
                
                combinedOrdersList.appendChild(orderCard);
                
                // Add to general totals
                totalGeneral += (order.total || 0);
                totalSubtotal += (order.subtotal || 0);
                totalServiceFee += (order.serviceFee || 0);
                if (order.paymentStatus === 'completed') {
                    totalPaid += (order.total || 0);
                } else {
                    totalPending += (order.total || 0);
                }
            });
            
            // Update summary
            updateCombinedSummary({
                subtotal: totalSubtotal,
                serviceFee: totalServiceFee,
                total: totalGeneral,
                paid: totalPaid,
                pending: totalPending
            }, orders);
        }
        
        // Update combined orders summary
        function updateCombinedSummary(totals, allOrders) {
            document.getElementById('combinedSubtotal').textContent = `R$ ${totals.subtotal ? totals.subtotal.toFixed(2).replace('.', ',') : '0,00'}`;
            document.getElementById('combinedServiceFee').textContent = `R$ ${totals.serviceFee ? totals.serviceFee.toFixed(2).replace('.', ',') : '0,00'}`;
            document.getElementById('combinedTotal').textContent = `R$ ${totals.total ? totals.total.toFixed(2).replace('.', ',') : '0,00'}`;
            document.getElementById('combinedPaidTotal').textContent = `R$ ${totals.paid ? totals.paid.toFixed(2).replace('.', ',') : '0,00'}`;
            document.getElementById('combinedPendingTotal').textContent = `R$ ${totals.pending ? totals.pending.toFixed(2).replace('.', ',') : '0,00'}`;
        }
        
        // Filter combined orders
        function filterCombinedOrders() {
            // This will be called when filters are applied
            if (window.ordersData) {
                displayCombinedOrders(window.ordersData);
            }
        }
        
        // Process all payments
        function processAllPayments() {
            if (!window.ordersData || window.ordersData.length === 0) {
                alert('Não há pedidos para processar.');
                return;
            }
            
            // Filter pending orders
            const pendingOrders = window.ordersData.filter(order => order.paymentStatus !== 'completed');
            
            if (pendingOrders.length === 0) {
                alert('Não há pedidos pendentes para processar.');
                return;
            }
            
            if (!confirm(`Tem certeza que deseja confirmar o pagamento de ${pendingOrders.length} pedidos pendentes?`)) {
                return;
            }
            
            // Process each pending order
            let processedCount = 0;
            pendingOrders.forEach(order => {
                if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                    window.ws.send(JSON.stringify({
                        type: 'updatePaymentStatus',
                        orderId: order.id,
                        paymentStatus: 'completed',
                        updatedBy: 'admin'
                    }));
                    processedCount++;
                }
            });
            
            alert(`${processedCount} pagamentos processados com sucesso!`);
            
            // Reload the combined orders view after a short delay
            setTimeout(() => {
                if (document.getElementById('combined').classList.contains('active')) {
                    loadCombinedOrders();
                }
            }, 1000);
        }
        
        // Logout function
        function logout() {
            if (confirm('Tem certeza que deseja sair?')) {
                // Clear admin access flags
                localStorage.removeItem('adminAccess');
                localStorage.removeItem('establishmentData');
                window.location.href = 'index.html';
            }
        }
    </script>
    
    <!-- History Section -->
    <section id="history" class="content-section">
        <h2>Histórico de Pedidos</h2>
        <p>Ações registradas no sistema de pedidos</p>
        
        <div class="orders-column">
            <div class="column-header">
                <h3>Ações Registradas</h3>
                <button class="btn btn-primary" onclick="loadOrderHistory()">Atualizar</button>
            </div>
            <div id="historyList">
                <p>Carregando histórico...</p>
            </div>
        </div>
    </section>
    
    <!-- Combined Orders Section -->
    <section id="combined" class="content-section">
        <h2>Pedidos Combinados</h2>
        <p>Todos os pedidos em um único container com cálculo automático</p>
            
        <div class="filters">
            <div class="filter-group">
                <label for="combinedDateFilter">Data</label>
                <input type="date" id="combinedDateFilter">
            </div>
            <div class="filter-group">
                <label for="combinedTableFilter">Mesa</label>
                <select id="combinedTableFilter">
                    <option value="">Todas</option>
                    <option value="1">Mesa 01</option>
                    <option value="2">Mesa 02</option>
                    <option value="3">Mesa 03</option>
                    <option value="4">Mesa 04</option>
                    <option value="5">Mesa 05</option>
                </select>
            </div>
            <div class="filter-group">
                <label for="combinedStatusFilter">Status</label>
                <select id="combinedStatusFilter">
                    <option value="">Todos</option>
                    <option value="pending">Pendente</option>
                    <option value="preparing">Em Preparo</option>
                    <option value="ready">Pronto</option>
                    <option value="delivered">Entregue</option>
                </select>
            </div>
            <div class="filter-group">
                <label for="combinedPaymentFilter">Pagamento</label>
                <select id="combinedPaymentFilter">
                    <option value="">Todos</option>
                    <option value="pending">Pendente</option>
                    <option value="completed">Pago</option>
                </select>
            </div>
            <div class="filter-group">
                <button class="btn btn-primary" onclick="filterCombinedOrders()" style="margin-top: 25px;">Filtrar</button>
            </div>
        </div>
            
        <div class="orders-container" style="grid-template-columns: 1fr;">
            <div class="orders-column">
                <div class="column-header">
                    <h3>Todos os Pedidos</h3>
                    <span id="combinedOrdersCount">0 pedidos encontrados</span>
                </div>
                    
                <div id="combinedOrdersList">
                    <!-- Combined orders will be added here dynamically -->
                    <p>Carregando pedidos combinados...</p>
                </div>
                    
                <div class="cart-summary" style="margin-top: 20px; background-color: #f8f9fa; border-radius: 10px; padding: 20px;">
                    <h3>Resumo Financeiro</h3>
                    <div class="cart-item">
                        <div>Subtotal Geral</div>
                        <div id="combinedSubtotal">R$ 0,00</div>
                    </div>
                    <div class="cart-item">
                        <div>Taxa de Serviço (10%)</div>
                        <div id="combinedServiceFee">R$ 0,00</div>
                    </div>
                    <div class="cart-item" style="font-weight: bold; font-size: 18px;">
                        <div>Total Geral</div>
                        <div id="combinedTotal">R$ 0,00</div>
                    </div>
                    <div class="cart-item" style="font-weight: bold; font-size: 18px; color: #27ae60;">
                        <div>Total Pago</div>
                        <div id="combinedPaidTotal">R$ 0,00</div>
                    </div>
                    <div class="cart-item" style="font-weight: bold; font-size: 18px; color: #f39c12;">
                        <div>Total Pendente</div>
                        <div id="combinedPendingTotal">R$ 0,00</div>
                    </div>
                </div>
                    
                <div style="margin-top: 20px; text-align: center;">
                    <button class="btn btn-success" onclick="processAllPayments()">Processar Todos os Pagamentos</button>
                </div>
            </div>
        </div>
    </section>
</body>
</html>