```
        // Get payment status text
        function getPaymentStatusText(paymentStatus) {
            switch (paymentStatus) {
                case 'pending': return 'Pendente';
                case 'completed': return 'Pago';
                default: return paymentStatus;
            }
        }
        
        // Initialize WebSocket connection
        function initWebSocket() {
            // Check if we're already connected
            if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                console.log('Já conectado ao servidor WebSocket');
                return;
            }
            
            // Connect to port 3002
            const ws = new WebSocket('ws://localhost:3002');
            
            ws.onopen = function() {
                console.log('Conectado ao servidor WebSocket');
                window.ws = ws;
                
                // Request existing orders when connection is established
                if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                    window.ws.send(JSON.stringify({
                        type: 'getExistingOrders'
                    }));
                }
            };
            
            ws.onmessage = function(event) {
                const data = JSON.parse(event.data);
                
                if (data.type === 'existingOrders') {
                    // Store orders data for combined view
                    window.ordersData = data.orders || [];
                    
                    // Load existing orders into the dashboard
                    var orders = data.orders || [];
                    for (var i = 0; i < orders.length; i++) {
                        var order = orders[i];
                        addNewOrderToDashboard(order);
                        addNewOrderToOrdersSection(order);
                        addNewOrderToKitchenSection(order);
                        addNewOrderToCounterSection(order);
                        // Add to payments section if payment is pending
                        if (order.paymentStatus === 'pending') {
                            addOrderToPaymentsSection(order);
                        }
                    }
                    console.log('Carregados ' + orders.length + ' pedidos existentes');
                    
                    // Load combined orders if the section is active
                    if (document.getElementById('combined').classList.contains('active')) {
                        displayCombinedOrders(window.ordersData);
                    }
                } else if (data.type === 'newOrder') {
                    // Add new order to all relevant sections
                    if (data.order) {
                        addNewOrderToDashboard(data.order);
                        addNewOrderToOrdersSection(data.order);
                        addNewOrderToKitchenSection(data.order);
                        addNewOrderToCounterSection(data.order);
                        // Add to payments section if payment is pending
                        if (data.order.paymentStatus === 'pending') {
                            addOrderToPaymentsSection(data.order);
                        }
                        
                        // Update orders data for combined view
                        if (window.ordersData) {
                            window.ordersData.push(data.order);
                        } else {
                            window.ordersData = [data.order];
                        }
                        
                        // Refresh combined orders if the section is active
                        if (document.getElementById('combined').classList.contains('active')) {
                            displayCombinedOrders(window.ordersData);
                        }
                        
                        // Show notification
                        alert('Novo pedido recebido: ' + data.order.id);
                        
                        // Add to notifications
                        addNotificationToDashboard('Novo pedido recebido: ' + data.order.id, data.order.id);
                    }
                } else if (data.type === 'statusUpdate') {
                    // Update status in all sections
                    updateOrderStatusUI(data.orderId, data.status);
                    
                    // Update orders data for combined view
                    if (window.ordersData) {
                        var orderIndex = -1;
                        for (var i = 0; i < window.ordersData.length; i++) {
                            if (window.ordersData[i].id === data.orderId) {
                                orderIndex = i;
                                break;
                            }
                        }
                        if (orderIndex !== -1) {
                            window.ordersData[orderIndex].status = data.status;
                            
                            // Refresh combined orders if the section is active
                            if (document.getElementById('combined').classList.contains('active')) {
                                displayCombinedOrders(window.ordersData);
                            }
                        }
                    }
                    
                    // Show notification based on status
                    var notificationMessage = '';
                    switch (data.status) {
                        case 'preparing':
                            notificationMessage = 'Pedido ' + data.orderId + ' está em preparação';
                            break;
                        case 'ready':
                            notificationMessage = 'Pedido ' + data.orderId + ' está pronto - Notificar garçom para entrega';
                            addNotificationToDashboard('Pedido ' + data.orderId + ' está pronto para entrega', data.orderId);
                            break;
                        case 'delivered':
                            notificationMessage = 'Pedido ' + data.orderId + ' foi entregue ao cliente';
                            addNotificationToDashboard('Pedido ' + data.orderId + ' foi entregue ao cliente', data.orderId);
                            break;
                        case 'completed':
                            notificationMessage = 'Pedido ' + data.orderId + ' foi concluído pelo cliente';
                            addNotificationToDashboard('Pedido ' + data.orderId + ' foi concluído pelo cliente', data.orderId);
                            break;
                    }
                    
                    if (notificationMessage) {
                        alert(notificationMessage);
                    }
                } else if (data.type === 'paymentStatusUpdate') {
                    // Update payment status in payments section
                    updatePaymentStatusUI(data.orderId, data.paymentStatus);
                    
                    // Update orders data for combined view
                    if (window.ordersData) {
                        var orderIndex = -1;
                        for (var i = 0; i < window.ordersData.length; i++) {
                            if (window.ordersData[i].id === data.orderId) {
                                orderIndex = i;
                                break;
                            }
                        }
                        if (orderIndex !== -1) {
                            window.ordersData[orderIndex].paymentStatus = data.paymentStatus;
                            
                            // Refresh combined orders if the section is active
                            if (document.getElementById('combined').classList.contains('active')) {
                                displayCombinedOrders(window.ordersData);
                            }
                        }
                    }
                    
                    // Show notification based on payment status
                    var notificationMessage = '';
                    switch (data.paymentStatus) {
                        case 'completed':
                            notificationMessage = 'Pagamento do pedido ' + data.orderId + ' foi confirmado';
                            addNotificationToDashboard('Pagamento do pedido ' + data.orderId + ' foi confirmado', data.orderId);
                            
                            // Clear order history after payment is completed
                            clearOrderHistory(data.orderId);
                            break;
                    }
                    
                    if (notificationMessage) {
                        alert(notificationMessage);
                    }
                }
            };
            
            ws.onclose = function() {
                console.log('Conexão WebSocket fechada');
                // Try to reconnect after 5 seconds
                setTimeout(initWebSocket, 5000);
            };
            
            ws.onerror = function(error) {
                console.error('Erro na conexão WebSocket:', error);
            };
        }
        
        // Update order status in UI
        function updateOrderStatusUI(orderId, status) {
            const orderCards = document.querySelectorAll('.order-card');
            orderCards.forEach(card => {
                const orderIdElement = card.querySelector('.order-id');
                if (orderIdElement && orderIdElement.textContent === orderId) {
                    const statusElement = card.querySelector('.order-status strong');
                    if (statusElement) {
                        statusElement.textContent = getStatusText(status);
                        statusElement.style.color = getStatusColor(status);
                    }
                }
            });
        }
        
        // Load order history
        function loadOrderHistory() {
            const orderActions = JSON.parse(localStorage.getItem('orderActions') || '[]');
            displayOrderHistory(orderActions);
        }
        
        // Display order history
        function displayOrderHistory(actions) {
            const historyContainer = document.getElementById('historyList');
            historyContainer.innerHTML = '';
            
            if (actions.length === 0) {
                historyContainer.innerHTML = '<p>Nenhuma ação registrada no histórico.</p>';
                return;
            }
            
            // Sort actions by timestamp (newest first)
            actions.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
            
            actions.forEach(action => {
                const actionElement = document.createElement('div');
                actionElement.className = 'order-card';
                actionElement.style.marginBottom = '20px';
                actionElement.style.border = '1px solid #eee';
                actionElement.style.borderRadius = '10px';
                actionElement.style.padding = '15px';
                
                // Format date
                const actionDate = new Date(action.timestamp);
                const formattedDate = actionDate.toLocaleDateString('pt-BR') + ' ' + actionDate.toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'});
                
                let actionDescription = '';
                switch (action.type) {
                    case 'updateStatus':
                        actionDescription = `Status do pedido ${action.orderId} atualizado para "${getStatusText(action.status)}"`;
                        if (action.sector && action.sector !== 'admin') {
                            actionDescription += ` por ${action.sector}`;
                        }
                        break;
                    case 'repeatOrder':
                        actionDescription = `Pedido ${action.orderId} repetido`;
                        break;
                    default:
                        actionDescription = `Ação desconhecida: ${action.type}`;
                }
                
                actionElement.innerHTML = `
                    <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                        <div><strong>${action.type === 'updateStatus' ? 'Atualização de Status' : action.type === 'repeatOrder' ? 'Repetição de Pedido' : 'Ação'}</strong></div>
                        <div>${formattedDate}</div>
                    </div>
                    <div>${actionDescription}</div>
                `;
                
                historyContainer.appendChild(actionElement);
            });
        }
        
        // Load combined orders
        function loadCombinedOrders() {
            const combinedOrdersList = document.getElementById('combinedOrdersList');
            combinedOrdersList.innerHTML = '<p>Carregando pedidos combinados...</p>';
            
            // In a real implementation, this would fetch orders from the server
            // For now, we'll simulate with a delay
            setTimeout(() => {
                // Get all orders from the WebSocket connection if available
                if (window.ordersData) {
                    displayCombinedOrders(window.ordersData);
                } else {
                    combinedOrdersList.innerHTML = '<p>Nenhum pedido encontrado.</p>';
                }
            }, 1000);
        }
        
        // Display combined orders
        function displayCombinedOrders(orders) {
            var combinedOrdersList = document.getElementById('combinedOrdersList');
            combinedOrdersList.innerHTML = '';
            
            if (orders.length === 0) {
                combinedOrdersList.innerHTML = '<p>Nenhum pedido encontrado.</p>';
                return;
            }
            
            var ordersByTable = {};
            orders.forEach(function(order) {
                var table = order.table || 'Outros';
                if (!ordersByTable[table]) {
                    ordersByTable[table] = [];
                }
                ordersByTable[table].push(order);
            });
            
            Object.keys(ordersByTable).forEach(function(table) {
                var tableContainer = document.createElement('div');
                tableContainer.style.marginBottom = '30px';
                
                var tableTitle = document.createElement('h3');
                tableTitle.textContent = 'Mesa ' + table;
                tableContainer.appendChild(tableTitle);
                
                ordersByTable[table].forEach(function(order) {
                    var orderElement = document.createElement('div');
                    orderElement.className = 'order-card';
                    orderElement.style.marginBottom = '20px';
                    orderElement.style.border = '1px solid #eee';
                    orderElement.style.borderRadius = '10px';
                    orderElement.style.padding = '15px';
                    
                    var orderDetails = document.createElement('div');
                    orderDetails.style.display = 'flex';
                    orderDetails.style.justifyContent = 'space-between';
                    orderDetails.style.marginBottom = '10px';
                    
                    var orderId = document.createElement('div');
                    orderId.style.fontWeight = 'bold';
                    orderId.textContent = 'Pedido ' + order.id;
                    orderDetails.appendChild(orderId);
                    
                    var status = document.createElement('div');
                    status.style.color = getStatusColor(order.status);
                    status.textContent = getStatusText(order.status);
                    orderDetails.appendChild(status);
                    
                    orderElement.appendChild(orderDetails);
                    
                    if (order.items) {
                        var itemsList = document.createElement('ul');
                        order.items.forEach(function(item) {
                            var itemElement = document.createElement('li');
                            itemElement.textContent = item.name + ' x ' + item.quantity;
                            itemsList.appendChild(itemElement);
                        });
                        orderElement.appendChild(itemsList);
                    }
                    
                    if (order.paymentStatus) {
                        var paymentStatus = document.createElement('div');
                        paymentStatus.style.color = getPaymentStatusColor(order.paymentStatus);
                        paymentStatus.textContent = getPaymentStatusText(order.paymentStatus);
                        orderElement.appendChild(paymentStatus);
                    }
                    
                    tableContainer.appendChild(orderElement);
                });
                
                combinedOrdersList.appendChild(tableContainer);
            });
        }
        
        // Add notification to dashboard
        function addNotificationToDashboard(message, orderId) {
            var notificationsContainer = document.getElementById('notifications');
            var notificationElement = document.createElement('div');
            notificationElement.style.marginBottom = '10px';
            notificationElement.style.border = '1px solid #eee';
            notificationElement.style.borderRadius = '10px';
            notificationElement.style.padding = '10px';
            notificationElement.textContent = message;
            notificationsContainer.appendChild(notificationElement);
        }
        
