            }
        }
        
        // Initialize WebSocket connection
        function initWebSocket() {
            // Check if we're already connected
            if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                console.log('Já conectado ao servidor WebSocket');
                return;
            }
            
            // Connect to port 3002
            const ws = new WebSocket('ws://localhost:3002');
            
            ws.onopen = function() {
                console.log('Conectado ao servidor WebSocket');
                window.ws = ws;
                
                // Request existing orders when connection is established
                if (window.ws && window.ws.readyState === WebSocket.OPEN) {
                    window.ws.send(JSON.stringify({
                        type: 'getExistingOrders'
                    }));
                }
            };
            
            ws.onmessage = function(event) {
                const data = JSON.parse(event.data);
                
                if (data.type === 'existingOrders') {
                    // Store orders data for combined view
                    window.ordersData = data.orders || [];
                    
                    // Load existing orders into the dashboard
                    var orders = data.orders || [];
                    for (var i = 0; i < orders.length; i++) {
                        var order = orders[i];
```

